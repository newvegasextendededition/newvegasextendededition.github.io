# Auto-detect text files and normalize to LF in repo
* text=auto

# Force LF (Unix style)
*.sh text eol=lf
*.bash text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.cs text eol=lf

# Force CRLF (Windows-specific)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no normalization at all)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
